# ── Estimate form delivery ───────────────────────────────────────────────
# The contact form posts to /api/estimate, which emails the lead via Resend
# (see src/app/api/estimate/route.ts). Get an API key at resend.com/api-keys
# and verify the domain ESTIMATE_FROM_EMAIL sends from. If any of these three
# are unset, submissions are only logged server-side, never emailed.
RESEND_API_KEY=
ESTIMATE_TO_EMAIL=estimates@martinezlandscaping.com
ESTIMATE_FROM_EMAIL=website@martinezlandscaping.com

# ── Site ─────────────────────────────────────────────────────────────────
# Canonical production URL (used for sitemap, robots, and OpenGraph).
# Overrides the active business's default URL if set.
NEXT_PUBLIC_SITE_URL=https://www.martinezlandscaping.com

# ── Active business (Summit Studio template system) ─────────────────────
# Which client's content/brand is live. See src/data/businesses/registry.ts
# for the full tenant list — add a new business there, then point this at
# its slug. Unset or unrecognized values fall back to the default tenant.
#   martinez-landscaping (default) · delaware-lawn-crew · pq-landscaping
NEXT_PUBLIC_ACTIVE_BUSINESS=martinez-landscaping
